{
  "expo": {
    "name": "HerSaathi",
    "slug": "hersaathi",
    "version": "1.0.8",
    "orientation": "portrait",
    "scheme": "hersaathi",
    "icon": "./image/icon-safe.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./image/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hersaathi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./image/adaptive-icon-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.hersaathi.app",
      "versionCode": 10,
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-font",
      "expo-asset",
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "officialEmail": "her.saathi.care@gmail.com",
      "privacyPolicyUrl": "https://hersaathi-60899.web.app/privacy-policy",
      "termsUrl": "https://hersaathi-60899.web.app/terms-of-use",
      "dataDeletionUrl": "https://hersaathi-60899.web.app/data-deletion",
      "cloudProvider": "Cloud Firestore",
      "authProvider": "Google",
      "androidPackage": "com.hersaathi.app"
    },
    "owner": "sanjeevmazumder"
  }
}
